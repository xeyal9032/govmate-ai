# GovMate AI — ortam değişkenleri şablonu
# Kopyala: cp .env.example .env.local
# Production (Vercel): aynı anahtarları Environment Variables'a ekle.
# Gizli dosyalar .gitignore'da; asla commit etme.

# ─── Zorunlu (uygulama çekirdeği) ───────────────────────────────────────────

# Uygulama kök URL (lokal / production)
# Lokal: http://localhost:3000
# Vercel: https://govmate-ai.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — platform.openai.com
OPENAI_API_KEY=

# Cron — Vercel cron /api/cron/reminders koruması (rastgele uzun şifre)
CRON_SECRET=

# ─── Stripe (opsiyonel — abonelik / ödeme) ─────────────────────────────────

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Dashboard → Products → Price ID
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_BUSINESS_MONTHLY=

# ─── E-posta (opsiyonel — son tarih hatırlatıcıları) ───────────────────────

RESEND_API_KEY=
EMAIL_FROM=GovMate AI <noreply@govmate.ai>

# ─── Upstash (opsiyonel — rate limit; yoksa bellek modu) ───────────────────

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Sentry (opsiyonel — hata izleme) ──────────────────────────────────────

NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── E2E Playwright (sadece lokal — Vercel'e ekleme) ───────────────────────
# Önce: npm run e2e:setup

E2E_USER_EMAIL=test@example.com
E2E_USER_PASSWORD=

# ─── Playwright / CI (genelde gerekmez) ────────────────────────────────────
# PORT=3000
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
# PLAYWRIGHT_SKIP_WEBSERVER=1
# CI=1
