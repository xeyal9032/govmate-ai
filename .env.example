# GovMate AI — ortam değişkenleri şablonu
# Kopyala: cp .env.example .env.local
# Production (Vercel): aynı anahtarları Environment Variables'a ekle.
# Gizli dosyalar .gitignore'da; asla commit etme.

# ─── Zorunlu (uygulama çekirdeği) ───────────────────────────────────────────

# Uygulama kök URL (lokal / production)
# Lokal: http://localhost:3000
# Vercel: https://govmate-ai.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — platform.openai.com
OPENAI_API_KEY=

# Cron — Vercel cron /api/cron/reminders koruması (rastgele uzun şifre)
CRON_SECRET=

# ─── Stripe (opsiyonel — abonelik / ödeme) ─────────────────────────────────

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Dashboard → Products → Price ID
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_BUSINESS_MONTHLY=

# ─── E-posta (opsiyonel — son tarih hatırlatıcıları) ───────────────────────

RESEND_API_KEY=
EMAIL_FROM=GovMate AI <noreply@govmate.ai>

# ─── Upstash (opsiyonel — rate limit; yoksa bellek modu) ───────────────────
# Production'da Upstash ZORUNLUDUR — aksi halde rate limit 503 döner.

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Supabase tip üretimi (geliştirme) ──────────────────────────────────────
# npm run gen:types — NEXT_PUBLIC_SUPABASE_URL'den project ID otomatik alınır
# İlk kullanım: npx supabase login
# SUPABASE_PROJECT_ID=  (opsiyonel; URL yoksa gerekli)

# ─── Sentry (opsiyonel — hata izleme + source map) ─────────────────────────
# DSN olmadan uygulama çalışır; DSN varsa aşağıdakiler önerilir.
#
# 1) sentry.io → Project (govmate-ai) → Client Keys (DSN)
# 2) Organization Settings → Auth Tokens → Create New Token
#    İzinler: org:read, project:releases, project:write
# 3) Vercel → govmate-ai → Settings → Environment Variables:
#    SENTRY_AUTH_TOKEN (Sensitive), SENTRY_ORG, SENTRY_PROJECT
#    Production + Preview ortamlarına ekle; deploy sonrası source map yüklenir.
#
# Lokal source map testi: SENTRY_AUTH_TOKEN doldur → npm run build

NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── E2E Playwright (lokal + GitHub Actions) ─────────────────────────────────
# Lokal: npm run e2e:setup → npm run test:e2e
#
# GitHub Actions secret'ları (Settings → Secrets → Actions):
#   NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
#   E2E_USER_EMAIL, E2E_USER_PASSWORD
#   E2E_ADMIN_EMAIL, E2E_ADMIN_PASSWORD  (opsiyonel — admin.spec.ts için)

E2E_USER_EMAIL=test@example.com
E2E_USER_PASSWORD=
# E2E_ADMIN_EMAIL=admin@example.com
# E2E_ADMIN_PASSWORD=

# ─── Playwright / CI (genelde gerekmez) ────────────────────────────────────
# PORT=3000
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
# PLAYWRIGHT_SKIP_WEBSERVER=1
# CI=1
