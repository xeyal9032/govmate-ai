{
  "name": "govmate-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:setup": "node scripts/ensure-e2e-user.mjs",
    "test:e2e": "playwright test",
    "test:e2e:flow": "playwright test e2e/document-flow.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "screenshots": "playwright test e2e/screenshots.spec.ts",
    "screenshots:gif": "node scripts/make-demo-gif.mjs",
    "sync:marketing": "node scripts/sync-marketing-screenshots.mjs",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:sentry": "node scripts/check-sentry.mjs",
    "check:upstash": "node scripts/check-upstash.mjs",
    "gen:types": "node scripts/gen-supabase-types.mjs",
    "gen:types:local": "npx supabase gen types typescript --local > src/types/supabase.generated.ts",
    "verify": "npm run check:i18n && npm run test && npm run lint && npm run build",
    "verify:all": "npm run verify && npm run test:e2e"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource/roboto": "^5.2.10",
    "@hookform/resolvers": "^5.4.0",
    "@napi-rs/canvas": "^0.1.100",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.54.0",
    "@stripe/stripe-js": "^9.6.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-intl": "^4.12.0",
    "next-themes": "^0.4.6",
    "openai": "^6.39.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.76.1",
    "resend": "^6.12.3",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "happy-dom": "^20.10.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
